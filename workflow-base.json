{
  "name": "EscolaFlux - CFO WhatsApp Base",
  "nodes": [
    {
      "name": "Webhook WhatsApp",
      "type": "n8n-nodes-base.webhook",
      "parameters": {
        "path": "escolaflux-whatsapp",
        "httpMethod": "POST"
      }
    },
    {
      "name": "Classificar intenção",
      "type": "n8n-nodes-base.function",
      "parameters": {
        "functionCode": "const text = $json.body?.text || '';\nreturn [{ intent: text.includes('caixa') ? 'dashboard' : 'geral', text }];"
      }
    }
  ],
  "connections": {
    "Webhook WhatsApp": {
      "main": [[{ "node": "Classificar intenção", "type": "main", "index": 0 }]]
    }
  }
}