# EscolaFlux - Variáveis de Ambiente
# Copie este arquivo para .env.local e preencha com seus valores

# Supabase
NEXT_PUBLIC_SUPABASE_URL=sua_url_do_projeto
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua_chave_anonima
SUPABASE_SERVICE_ROLE_KEY=sua_chave_service_role (apenas server-side)

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=EscolaFlux

# WhatsApp (Meta Cloud API) - Fase 2
WHATSAPP_ACCESS_TOKEN=seu_token_aqui
WHATSAPP_PHONE_NUMBER_ID=seu_phone_number_id
WHATSAPP_VERIFY_TOKEN=seu_verify_token_personalizado

# Email (Resend ou SendGrid) - Fase 2
RESEND_API_KEY=sua_chave_resend
FROM_EMAIL=noreply@escoflux.com.br

#IA (Anthropic Claude) - Fase 2
ANTHROPIC_API_KEY=sua_chave_claude

# Monitoring (Sentry) - Fase 3
NEXT_PUBLIC_SENTRY_DSN=sua_dsn_sentry
